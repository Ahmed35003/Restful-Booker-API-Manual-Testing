                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response is an array\", function () {\r",
                  "    pm.expect(pm.response.json()).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Array is not empty\", function () {\r",
                  "    pm.expect(pm.response.json().length).to.be.above(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Each item has bookingid\", function () {\r",
                  "    pm.response.json().forEach(function (item) {\r",
                  "        pm.expect(item).to.have.property(\"bookingid\");\r",
                  "    });\r",
